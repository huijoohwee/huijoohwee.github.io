{
  "@context": "https://huijoohwee.github.io/schema/AgenticRAG/v1/context.jsonld",
  "@id": "rag:FlowWidgetBundle",
  "@type": "rag:Directive",
  "schemaVersion": "1.0.1",
  "rdfs:label": [
    { "@value": "Widget bundle contract", "@language": "en-us" },
    { "@value": "Flow Widget bundle 契约", "@language": "zh-cn" }
  ],
  "rdfs:comment": [
    {
      "@value": "Contract for a project-agnostic JSON envelope that imports/exports shared widget registry mappings and optionally includes a GraphData payload for import→render round-trips.",
      "@language": "en-us"
    },
    {
      "@value": "用于导入/导出 Flow Widget Registry 映射的领域无关 JSON 封装格式，并可选携带 GraphData 用于 import→render 的往返。",
      "@language": "zh-cn"
    }
  ],
  "widgetBundleContracts": {
    "bundleKindAndVersion": [
      {
        "@value": "Bundle documents must declare kind='kg:flow:widgetBundle' and version=1. Parsers must reject other versions unless explicitly supported.",
        "@language": "en-us"
      },
      {
        "@value": "Bundle 文档必须声明 kind='kg:flow:widgetBundle' 且 version=1。解析器必须拒绝其他版本（除非显式支持）。",
        "@language": "zh-cn"
      }
    ],
    "registryPayload": [
      {
        "@value": "Bundles carry a 'registry' array whose items match the shared widget Registry entry shape (id/nodeTypeId/widgetTypeId/formId/fields/ports/updatedAt). Consumers must validate and normalize before persisting.",
        "@language": "en-us"
      },
      {
        "@value": "Registry field/port items may include an optional boolean 'isHidden'. When true, UIs must hide that field/port in shared widget rendering and suppress Flow port handles derived from it.",
        "@language": "en-us"
      },
      {
        "@value": "Registry entries may include an optional 'schemaMappings' array for in-editor dataflow. Each item declares fromPath/toPath and optional transformId/reduceId. Consumers must validate ids; unknown ids must be treated as no-op rather than failing import.",
        "@language": "en-us"
      },
      {
        "@value": "Bundle 携带 'registry' 数组，其元素匹配共享 widget Registry entry 形状（id/nodeTypeId/widgetTypeId/formId/fields/ports/updatedAt）。消费方必须在持久化前做校验与归一化。",
        "@language": "zh-cn"
      },
      {
        "@value": "Registry 的 field/port 项可包含可选布尔字段 'isHidden'。当为 true 时，UI 必须在共享 widget 渲染中隐藏该 field/port，并抑制由其派生的 Flow 端口句柄。",
        "@language": "zh-cn"
      }
      ,
      {
        "@value": "Registry entry 可包含可选的 'schemaMappings' 数组用于编辑器内数据流计算。每项包含 fromPath/toPath，以及可选 transformId/reduceId。消费方必须校验这些 id；未知 id 必须按 no-op 处理而不是导致导入失败。",
        "@language": "zh-cn"
      }
    ],
    "graphMetadataWiring": [
      {
        "@value": "Import pipelines may write registry entries into GraphData.metadata['flow:widgetRegistry'] to enable immediate Storyboard/frontmatter-flow widget rendering after graph commit.",
        "@language": "en-us"
      },
      {
        "@value": "导入流水线可将 registry entries 写入 GraphData.metadata['flow:widgetRegistry']，以便图数据 commit 后立即启用 Storyboard/frontmatter-flow widget 的渲染。",
        "@language": "zh-cn"
      }
    ],
    "noChurnPolicy": [
      {
        "@value": "Auto-apply must be idempotent: if the imported registry signature matches the current store snapshot, do not rewrite or re-persist.",
        "@language": "en-us"
      },
      {
        "@value": "自动应用必须幂等：若导入 registry 的签名与当前 store 快照一致，则不得重复写入或重复持久化。",
        "@language": "zh-cn"
      }
    ],
    "dragAndDropPayload": [
      {
        "@value": "UIs may support drag-and-drop creation of workflow nodes from registry entries. Drag payloads should be versioned and project-agnostic (e.g. kind='kg:flow:widgetDrag', version=1) and resolve to a registry entry id in the active store snapshot.",
        "@language": "en-us"
      },
      {
        "@value": "UI 可支持从 registry entries 拖拽创建工作流节点。拖拽 payload 应版本化且领域无关（例如 kind='kg:flow:widgetDrag', version=1），并解析为当前 store 快照中的 registry entry id。",
        "@language": "zh-cn"
      }
    ],
    "imageToThreeJsSkillProjection": [
      {
        "@value": "The source-owned `image.to-threejs` skill accepts one connected image source before a local property fallback and emits `knowgrph-image-to-threejs/v1`. Supported PNG/JPG/JPEG sources project as a Three.js textured plane; SVG projects as shape geometry. Success uses `mediaRenderMode: threejs` with zero model tokens and zero estimated cost. Missing or unsupported sources must return typed errors before render work. The canonical contract is `knowgrph/docs/documents/knowgrph-image-to-threejs-api.md`; schema consumers must not introduce a provider route, agent variant, alias parser, copied external implementation, or additional runtime dependency.",
        "@language": "en-us"
      },
      {
        "@value": "由源代码拥有的 `image.to-threejs` skill 先读取已连接的图片源，再回退到本地属性，并输出 `knowgrph-image-to-threejs/v1`。支持的 PNG/JPG/JPEG 以 Three.js textured plane 投影，SVG 以 shape geometry 投影。成功结果使用 `mediaRenderMode: threejs`，模型 token 与预估成本均为零。缺失或不支持的输入必须在渲染前返回类型化错误。规范契约位于 `knowgrph/docs/documents/knowgrph-image-to-threejs-api.md`；schema 消费方不得新增 provider 路由、agent 变体、别名解析器、复制外部实现或额外运行时依赖。",
        "@language": "zh-cn"
      }
    ],
    "exportSurfaces": [
      {
        "@value": "Export surfaces may include: exporting registry-only bundles (Widget Manager), exporting workflow bundles (draft graph + registry), and exporting per-node bundles (node subgraph + matching registry). All must preserve kind/version.",
        "@language": "en-us"
      },
      {
        "@value": "导出面可包括：仅导出 registry 的 bundle（Widget Manager）、导出工作流 bundle（draft graph + registry）、导出单节点 bundle（节点子图 + 匹配 registry）。均必须保留 kind/version。",
        "@language": "zh-cn"
      }
    ],
    "multiNodeEditorRendering": [
      {
        "@value": "When multiple widget overlays are visible simultaneously, UIs must avoid DOM id collisions by scoping form control ids per node and applying a deterministic offset/stacking strategy to reduce panel overlap.",
        "@language": "en-us"
      },
      {
        "@value": "当多个 widget 覆层同时可见时，UI 必须通过按节点作用域化 form 控件 id 来避免 DOM id 冲突，并使用确定性偏移/堆叠策略减少面板重叠。",
        "@language": "zh-cn"
      }
    ]
  }
}
